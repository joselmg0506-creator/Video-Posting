.env
data/*
# state.json is tracked so the cloud (GitHub Actions) keeps dedup history across runs
!data/state.json
# suggestions.json (daily competitor-aware dashboard tips) is tracked so the dashboard build picks it up
!data/suggestions.json
# history.json (daily view snapshots) is tracked so the cloud accumulates real day-over-day trends
!data/history.json
__pycache__/
*.pyc
.venv/
venv/
samples/
secrets/
