# Anthropic — AI commentary for the transform stage (https://console.anthropic.com)
# Only this key is needed for the AI layer; the voiceover/TTS is fully offline.
ANTHROPIC_API_KEY=

# Discord webhook for post/failure/metrics notifications (optional)
# Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# YouTube cookies — required to download from YouTube (it bot-blocks yt-dlp otherwise).
# Export a cookies.txt for youtube.com with the "Get cookies.txt LOCALLY" browser
# extension, save it (e.g. ./secrets/youtube_cookies.txt), and point this at it.
YOUTUBE_COOKIES_FILE=
# Alternative (often fails on Chrome/Edge due to encrypted cookie DB): a browser name.
YOUTUBE_COOKIES_BROWSER=

# Twitch (https://dev.twitch.tv/console)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# TikTok (https://developers.tiktok.com - requires app approval for Content Posting API)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8080/callback
# Obtained after running `python -m src.auth_tiktok` once
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# YouTube Shorts (https://console.cloud.google.com — enable YouTube Data API v3)
# Save the OAuth client JSON to ./secrets/youtube_client_secret.json
YOUTUBE_CLIENT_SECRETS=./secrets/youtube_client_secret.json
YOUTUBE_TOKEN_FILE=./secrets/youtube_token.json
